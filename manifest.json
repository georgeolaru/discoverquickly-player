{
  "manifest_version": 3,
  "name": "Discover Quickly Queue Player",
  "version": "0.1.3",
  "description": "Autoplay preview tracks inside Discover Quickly playlist cards and bookmark interesting finds.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Discover Quickly Queue Player",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://discoverquickly.com/*"
      ],
      "js": [
        "page.js"
      ],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ]
}
